{
  "name": "fb-video-downloader",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "next build && electron-builder"
  },
  "build": {
    "appId": "com.randytsay.fb-video-downloader",
    "productName": "FB Video Downloader",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    },
    "files": [
      "**/*",
      "!.next/cache",
      "!.next/dev",
      "!node_modules/.cache",
      "!dist",
      "!electron",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "puppeteer-core": "^24.39.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "youtube-dl-exec": "^3.1.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
